PORT=3001

JWT_SECRET=your-long-random-secret

# Supabase: Project → Connect → copy BOTH strings for Prisma. Replace YOUR_DB_PASSWORD (same password in both lines).
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:YOUR_DB_PASSWORD@aws-[N]-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:YOUR_DB_PASSWORD@aws-[N]-[REGION].pooler.supabase.com:5432/postgres"

# Optional overrides
# JWT_EXPIRES_IN=7d
# BCRYPT_SALT_ROUNDS=12

# Optional: Helius, QuickNode, or public devnet — enables on-chain USDC pay verification
# SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
# HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# Set to false to keep payload-only pay checks (e.g. local smoke script) even when RPC is set
# ONCHAIN_PAY_VERIFY=false

# SPL USDC mint (devnet default baked in server)
# USDC_MINT_DEVNET=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Echoed in HTTP 402 `anchor.programId` — set after you deploy your own program
# MAXIS_ANCHOR_PROGRAM_ID=...
